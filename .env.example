# Copy this to .env.local and fill in your values
# Also add these in Vercel → Settings → Environment Variables

MONGODB_URI=mongodb+srv://indiaanilkumawat_db_user:<db_password>@assignment.ogxz8jk.mongodb.net/assignmenthub?retryWrites=true&w=majority&appName=assignment
JWT_SECRET=your_long_random_secret_here

# ADMIN_PASSWORD is the INITIAL (bootstrap) admin password only.
# On first login it is stored (hashed) in the database. After you change the
# password from Admin → Password, the new password lives in the database and
# this variable is no longer used.
ADMIN_PASSWORD=your_strong_admin_password_here

# Cloudinary — powers the admin "GIF Banner" upload (Admin → GIF tab).
# Get these from Cloudinary Dashboard → Settings → API Keys.
# NOTE: keep CLOUDINARY_API_SECRET server-side only. Never commit real values.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
